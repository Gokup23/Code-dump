class HamiltonianCycle:
    def __init__(self, num_vertices):
        self.V = num_vertices
        # Initialize an empty adjacency matrix with 0s
        self.graph = [[0 for column in range(num_vertices)] 
                      for row in range(num_vertices)]
        self.cycles = [] # To store all found cycles

    def is_safe(self, v, pos, path):
        # 1. Check if this vertex is adjacent to the previously added vertex
        if self.graph[path[pos - 1]][v] == 0:
            return False

        # 2. Check if the vertex has already been visited (is in the path)
        if v in path:
            return False

        return True

    def find_cycles_util(self, path, pos):
        # BASE CASE: If all vertices are included in the path
        if pos == self.V:
            # Check if there is an edge from the last vertex back to the first
            if self.graph[path[pos - 1]][path[0]] == 1:
                # Cycle found! Let's format it for printing
                complete_cycle = list(path)
                complete_cycle.append(path[0]) # Add start node to the end
                self.cycles.append(complete_cycle)
            return

        # Try different vertices as the next candidate in the cycle
        for v in range(1, self.V):
            if self.is_safe(v, pos, path):
                path[pos] = v # Add vertex to path
                
                # Recurse to build the rest of the path
                self.find_cycles_util(path, pos + 1)
                
                # BACKTRACKING STEP: 
                # Remove current vertex from path to try other combinations
                path[pos] = -1

    def find_all_cycles(self):
        # Initialize path array with -1 (meaning empty)
        path = [-1] * self.V
        
        # We can always start the cycle from vertex 0
        path[0] = 0 

        # Start the recursive utility function from position 1
        self.find_cycles_util(path, 1)

        # Print results
        if not self.cycles:
            print("No Hamiltonian Cycle exists in this graph.")
        else:
            print(f"Found {len(self.cycles)} Hamiltonian Cycle(s):")
            for cycle in self.cycles:
                print(" -> ".join(map(str, cycle)))

