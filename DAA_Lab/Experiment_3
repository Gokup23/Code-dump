#Experiment3 - Given two sequences, to find the length of longest subsequence present in both of them. A subsequence is a sequence that appears in the same relative order, but not necessarily contiguous. For example. "abc", "abg",
#"bdf", "aeg", "acefg", etc are subsequences of "abcdefg"

def longest_common_subsequence(text1, text2):
    m = len(text1)
    n = len(text2)
    
    # Step 1: Create a 2D DP table initialized with zeros
    # Size will be (m+1) x (n+1)
    dp = [[0] * (n + 1) for _ in range(m + 1)]
    
    # Step 2: Build the table bottom-up
    for i in range(1, m + 1):
        for j in range(1, n + 1):
            
            # Note: We use i-1 and j-1 because the strings are 0-indexed, 
            # but our DP table is 1-indexed to handle the empty string base case.
            if text1[i - 1] == text2[j - 1]:
                # Characters match: diagonal + 1
                dp[i][j] = 1 + dp[i - 1][j - 1]
            else:
                # Characters don't match: max of top or left
                dp[i][j] = max(dp[i - 1][j], dp[i][j - 1])
                
    # Step 3: The bottom-right cell contains the length of the LCS
    return dp[m][n]

# --- Example Execution ---
seq1 = "abcde"
seq2 = "ace" 
# The longest common subsequence is "ace", which has a length of 3.

lcs_length = longest_common_subsequence(seq1, seq2)
print(f"Sequence 1: {seq1}")
print(f"Sequence 2: {seq2}")
print(f"Length of Longest Common Subsequence: {lcs_length}")
