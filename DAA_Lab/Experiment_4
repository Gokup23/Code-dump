def select_activities(start_times, finish_times):
    # Combine start and finish times into a single list of tuples for easy sorting
    # e.g., [(1, 2), (3, 4), (0, 6), ...]
    activities = list(zip(start_times, finish_times))
    
    # Step 1: Sort the activities based on their FINISH time (index 1 of the tuple)
    activities.sort(key=lambda x: x[1])
    
    selected_activities = []
    
    # Step 2: The first activity in the sorted list is always selected
    # (We are assuming there is at least one activity)
    first_activity = activities[0]
    selected_activities.append(first_activity)
    
    # Keep track of when the last selected activity finished
    last_finish_time = first_activity[1]
    
    # Step 3: Iterate through the remaining activities
    for i in range(1, len(activities)):
        current_activity = activities[i]
        
        # If this activity starts AFTER or EXACTLY WHEN the last one finished, pick it!
        if current_activity[0] >= last_finish_time:
            selected_activities.append(current_activity)
            # Update the finish time to the one we just picked
            last_finish_time = current_activity[1]
            
    return selected_activities

# --- Driver Code ---
# Example: 6 activities
starts =  [1, 3, 0, 5, 8, 5]
finishes = [2, 4, 6, 7, 9, 9]

# Note: The arrays above are already sorted by finish time for convenience, 
# but the code handles unsorted arrays perfectly.

max_activities = select_activities(starts, finishes)

print("The maximum number of activities selected are:")
for act in max_activities:
    print(f"Start: {act[0]}, Finish: {act[1]}")

