from collections import defaultdict

class Graph:
    def __init__(self, vertices):
        self.V = vertices
        # Use a dictionary of lists to represent the adjacency list
        self.graph = defaultdict(list)

    def add_edge(self, u, v):
        self.graph[u].append(v)
        self.graph[v].append(u)

    def print_approximate_vertex_cover(self):
        # Array to keep track of which vertices have a "guard"
        # We also use this to track which vertices' edges have been "covered"
        visited = [False] * self.V

        # Step 1: Iterate through all vertices to find an uncovered edge
        for u in range(self.V):
            
            # If vertex 'u' doesn't have a guard, let's look at its edges
            if not visited[u]:
                
                # Check all vertices 'v' connected to 'u'
                for v in self.graph[u]:
                    
                    # Step 2 & 3: If we find an edge (u, v) where NEITHER side has a guard...
                    if not visited[v]:
                        
                        # Step 4: Add guards to BOTH ends of the edge!
                        visited[u] = True
                        visited[v] = True
                        
                        # Break out of the inner loop because 'u' is now guarded,
                        # so all its other edges are implicitly covered.
                        break
        
        # Collect and print the final Vertex Cover
        cover = []
        for i in range(self.V):
            if visited[i]:
                cover.append(i)
                
        print(f"Approximate Vertex Cover includes vertices: {cover}")
        print(f"Total vertices in cover: {len(cover)}")

