NO_OF_CHARS = 256

def get_next_state(pat, m, state, x):
    # If the character 'x' matches the pattern at the current state, 
    # we successfully move to the next state!
    if state < m and x == ord(pat[state]):
        return state + 1
    
    # If it doesn't match, we need to figure out where to fall back to.
    # We look for the longest prefix of the pattern that matches a suffix 
    # of what we've seen so far.
    for ns in range(state, 0, -1):
        if ord(pat[ns-1]) == x:
            is_prefix = True
            for i in range(ns-1):
                if pat[i] != pat[state - ns + 1 + i]:
                    is_prefix = False
                    break
            if is_prefix:
                return ns
    return 0

def compute_tf(pat, m):
    # Create the 2D Transition Table (States x Characters)
    TF = [[0 for i in range(NO_OF_CHARS)] for _ in range(m+1)]
    for state in range(m+1):
        for x in range(NO_OF_CHARS):
            z = get_next_state(pat, m, state, x)
            TF[state][x] = z
    return TF

def search_finite_automata(pat, txt):
    m = len(pat)
    n = len(txt)
    
    # Pre-process the pattern to build the machine
    TF = compute_tf(pat, m)
    
    # Start at state 0
    state = 0
    for i in range(n):
        # Update the state based on the current text character
        state = TF[state][ord(txt[i])]
        
        # If we reach the final state, we found a match!
        if state == m:
            print(f"Finite Automata: Pattern found at index {i - m + 1}")

