def search_rabin_karp(pat, txt, q=101):
    # d is the number of characters in the input alphabet (ASCII)
    d = 256 
    m = len(pat)
    n = len(txt)
    p = 0    # hash value for pattern
    t = 0    # hash value for txt window
    h = 1

    # The value of h would be "pow(d, m-1)%q"
    for i in range(m-1):
        h = (h * d) % q

    # Calculate the hash value of pattern and first window of text
    for i in range(m):
        p = (d * p + ord(pat[i])) % q
        t = (d * t + ord(txt[i])) % q

    # Slide the pattern over text one by one
    for i in range(n - m + 1):
        # If the hash values match, then only check characters one by one
        if p == t:
            match = True
            for j in range(m):
                if txt[i + j] != pat[j]:
                    match = False
                    break
            
            # If all characters matched (no collision fake-out)
            if match:
                print(f"Rabin-Karp: Pattern found at index {i}")

        # Calculate hash value for next window of text
        if i < n - m:
            # Remove leading digit, add trailing digit
            t = (d * (t - ord(txt[i]) * h) + ord(txt[i + m])) % q
            
            # We might get negative value of t, converting it to positive
            if t < 0:
                t = t + q
