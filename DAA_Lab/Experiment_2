#Sort a given set of n integer elements using
#Counting Sort
#Merge Sort
#Compare the time complexity.

#Merge Sort
def merge_sort(arr):
    if len(arr) > 1:
        # Step 1: Find the middle and divide the array
        mid = len(arr) // 2
        left_half = arr[:mid]
        right_half = arr[mid:]

        # Step 2: Recursively sort both halves
        merge_sort(left_half)
        merge_sort(right_half)

        # Step 3: Merge the sorted halves back together
        i = j = k = 0 # Pointers for left_half, right_half, and main arr

        while i < len(left_half) and j < len(right_half):
            if left_half[i] < right_half[j]:
                arr[k] = left_half[i]
                i += 1
            else:
                arr[k] = right_half[j]
                j += 1
            k += 1

        # Check if any elements were left over in either half
        while i < len(left_half):
            arr[k] = left_half[i]
            i += 1
            k += 1

        while j < len(right_half):
            arr[k] = right_half[j]
            j += 1
            k += 1

#Counting sort
def counting_sort(arr):
    if not arr:
        return
        
    # Step 1: Find the maximum value to know the range
    max_val = max(arr)
    
    # Step 2: Initialize the count array and output array
    count = [0] * (max_val + 1)
    output = [0] * len(arr)
    
    # Step 3: Store the frequency of each element
    for num in arr:
        count[num] += 1
        
    # Step 4: Modify count array to store the cumulative sum.
    # This tells us the exact ending position of each element in the output array.
    for i in range(1, len(count)):
        count[i] += count[i - 1]
        
    # Step 5: Build the output array (iterating backwards maintains stability)
    for i in range(len(arr) - 1, -1, -1):
        num = arr[i]
        output[count[num] - 1] = num
        count[num] -= 1
        
    # Step 6: Copy the sorted elements back into original array
    for i in range(len(arr)):
        arr[i] = output[i]

"""
EXPERIMENT 2: Merge Sort vs Counting Sort

1. MERGE SORT
- Paradigm: Divide and Conquer (Comparison-based).
- Time Complexity: O(n log n) for all cases.
- Space Complexity: O(n) auxiliary space for the merged sub-arrays.
- Best for: General purpose sorting, large datasets, or when the 
  range of values is massive/unknown.

2. COUNTING SORT
- Paradigm: Hashing/Frequency Counting (Non-comparison-based).
- Time Complexity: O(n + k), where k is the maximum element.
- Space Complexity: O(n + k) auxiliary space for the count and output arrays.
- Best for: Arrays where the maximum value (k) is relatively small 
  (e.g., k = O(n)). 

THE CORE TRADEOFF: Counting sort breaks the O(n log n) lower bound 
of comparison sorting, achieving linear time, but it severely sacrifices 
space efficiency if the numbers are spread very far apart.
"""