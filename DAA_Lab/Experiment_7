# Number of vertices in the graph
V = 4

# Define infinity as a very large number
INF = float('inf')

def floyd_warshall(graph):
    # Create a 2D array (matrix) to store the shortest path distances.
    # We initialize it by copying the input graph.
    dist = list(map(lambda i: list(map(lambda j: j, i)), graph))

    # Phase 1: k is the intermediate vertex
    for k in range(V):
        # Phase 2: i is the source vertex
        for i in range(V):
            # Phase 3: j is the destination vertex
            for j in range(V):
                # Core DP Logic: 
                # If path through 'k' is shorter than direct path, update it!
                if dist[i][k] + dist[k][j] < dist[i][j]:
                    dist[i][j] = dist[i][k] + dist[k][j]

    print_solution(dist)

def print_solution(dist):
    print("Following matrix shows the shortest distances between every pair of vertices:")
    for i in range(V):
        row = []
        for j in range(V):
            if dist[i][j] == INF:
                row.append("INF")
            else:
                row.append(str(dist[i][j]))
        # Formatting for a clean grid output
        print("\t".join(row))

